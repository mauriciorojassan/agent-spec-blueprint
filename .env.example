# Proveedor LLM actual: openai, ollama, etc.
AI_PROVIDER=openai

# URL base del endpoint LLM (OpenAI u otro; para Ollama sería algo como http://localhost:11434/v1)
AI_BASE_URL=https://api.openai.com/v1

# API key del proveedor (no commitear .env)
AI_API_KEY=sk-...

# Nombre del modelo por defecto (mini/cheap si es posible)
AI_MODEL=gpt-4o-mini
